#!/bin/sh
#
# commit-msg hook: determine semver bump type from conventional commit message
# and store it for the post-commit hook to apply.
#
# Skip with: SKIP_VERSION_BUMP=1 git commit ...

if [ "$SKIP_VERSION_BUMP" = "1" ]; then
  exit 0
fi

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits
case "$COMMIT_MSG" in
  Merge*) exit 0 ;;
esac

# Determine bump type
BUMP="patch"

if echo "$COMMIT_MSG" | grep -qiE "^feat(\(.+\))?:"; then
  BUMP="minor"
fi

if echo "$COMMIT_MSG" | grep -qiE "^[a-z]+(\(.+\))?!:" || \
   echo "$COMMIT_MSG" | grep -q "BREAKING CHANGE"; then
  BUMP="major"
fi

# Store bump type for post-commit hook
echo "$BUMP" > "$(git rev-parse --git-dir)/.version-bump"

exit 0
